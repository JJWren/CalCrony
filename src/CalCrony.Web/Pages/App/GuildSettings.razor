@page "/app/guilds/{GuildId:long}/settings"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject CalCronyWebApiClient Api
@inject IJSRuntime Js

<PageTitle>Server settings — CalCrony</PageTitle>

<p class="meta-mono text-uppercase mb-2"><a href="/app/guilds/@GuildId/events">← Back to events</a></p>
<h1 class="h3">Server settings</h1>
@if (!isManager)
{
    <p class="text-body-secondary">Read-only — server managers can edit these here or in Discord with <code>/settings</code>.</p>
}

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="row g-3">
        <div class="col-12 col-md-6">
            <div class="card p-3 h-100">
                <div class="fw-bold">Timezone</div>
                @if (isManager)
                {
                    <label class="form-label small mt-2 mb-1" for="gs-tz">Pick the server's timezone</label>
                    <div class="d-flex gap-2">
                        <TimeZonePicker Id="gs-tz" @bind-Value="timezoneInput" />
                        <button class="btn btn-outline-primary btn-sm" @onclick="SaveTimezoneAsync" disabled="@busy">Save</button>
                    </div>
                    @if (saveMessage is not null)
                    {
                        <div class="meta-mono mt-2">@saveMessage</div>
                    }
                }
                else
                {
                    <p class="meta-mono mb-0 mt-2">@(settings?.TimeZone ?? "…")</p>
                }
                <div class="mt-3 pt-2 border-top">
                    <div class="fw-bold small">Default events channel</div>
                    <p class="meta-mono mb-1 mt-1">@(settings?.DefaultChannelId is long ch ? $"#{ch}" : "not set")</p>
                    <p class="text-body-secondary small mb-0">Set in Discord with <code>/settings default-channel</code> — the web has no channel list. Web-created events and reminders post there.</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card p-3 h-100">
                <div class="fw-bold">Calendar feed</div>
                <p class="text-body-secondary small mt-1 mb-2">Subscribe from Google, Apple, or Outlook — anyone with this URL can read this server's events.</p>
                @if (feedUrl is null)
                {
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                }
                else
                {
                    <p class="meta-mono text-break mb-2">@feedUrl</p>
                    <button class="btn btn-outline-primary btn-sm align-self-start" @onclick="CopyAsync">@copyLabel</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public long GuildId { get; set; }

    private GuildSettingsDto? settings;
    private string? feedUrl;
    private string? error;
    private string copyLabel = "Copy URL";
    private bool isManager;
    private bool busy;
    private string timezoneInput = "";
    private string? saveMessage;

    protected override async Task OnParametersSetAsync()
    {
        var settingsResult = await Api.GetGuildSettingsAsync(GuildId);
        if (!settingsResult.Success)
        {
            error = settingsResult.Error;
            return;
        }

        settings = settingsResult.Value;
        timezoneInput = settings?.TimeZone ?? "UTC";
        isManager = (await Api.GetMyGuildsAsync()).Value?.Guilds
            .Any(g => g.Id == GuildId && g.CanManage) ?? false;

        var feedResult = await Api.GetFeedTokenAsync(GuildId);
        if (feedResult.Success && feedResult.Value is not null)
        {
            feedUrl = Api.FeedUrl(feedResult.Value);
        }
    }

    private async Task SaveTimezoneAsync()
    {
        saveMessage = null;
        var trimmed = timezoneInput.Trim();
        if (trimmed.Length == 0)
        {
            saveMessage = "❌ Enter an IANA timezone id, e.g. America/Chicago.";
            return;
        }

        busy = true;
        // Read-modify-write: preserve the bot-managed DefaultChannelId.
        var result = await Api.PutGuildSettingsAsync(GuildId, new GuildSettingsDto(trimmed, settings?.DefaultChannelId));
        busy = false;
        if (!result.Success || result.Value is null)
        {
            saveMessage = $"❌ {result.Error}";
            return;
        }

        settings = result.Value;
        saveMessage = $"🌍 Saved — {result.Value.TimeZone}.";
    }

    private async Task CopyAsync()
    {
        var ok = await Js.InvokeAsync<bool>("calcronyCopy", feedUrl);
        copyLabel = ok ? "Copied ✓" : "Copy failed";
        await Task.Delay(1500);
        copyLabel = "Copy URL";
    }
}
