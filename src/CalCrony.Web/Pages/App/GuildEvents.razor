@page "/app/guilds/{GuildId:long}/events"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject CalCronyWebApiClient Api

<PageTitle>Events — CalCrony</PageTitle>

<p class="meta-mono text-uppercase mb-2"><a href="/app">← My servers</a></p>
<div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
    <h1 class="h3 mb-0">Upcoming events</h1>
    <div class="d-flex align-items-center gap-3">
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="includePast" @bind="includePast" @bind:after="LoadAsync" />
            <label class="form-check-label meta-mono" for="includePast">include past</label>
        </div>
        <a class="btn btn-primary btn-sm" href="/app/guilds/@GuildId/events/new">＋ New event</a>
    </div>
</div>

@if (error is not null)
{
    <div class="alert alert-danger mt-3">@error</div>
}
else if (events is null)
{
    <div class="spinner-border text-primary mt-3" role="status"></div>
}
else if (events.Count == 0)
{
    <p class="text-body-secondary mt-3">No events yet — create one in Discord with <code>/create</code>.</p>
}
else
{
    <div class="d-flex flex-column gap-3 mt-3">
        @foreach (var ev in events)
        {
            <EventCard Event="ev" />
        }
    </div>
}

<h2 class="h6 mt-4 mb-2">Remind me</h2>
<div class="card p-3" style="max-width:560px">
    <p class="text-body-secondary small mb-2">Posts a reminder mentioning you in this server's default events channel.</p>
    <div class="d-flex gap-2 flex-wrap align-items-end">
        <div>
            <label class="form-label small mb-1" for="rem-when">When</label>
            <input id="rem-when" class="form-control form-control-sm" placeholder="in 30 minutes" style="width:11rem" @bind="reminderWhen" />
        </div>
        <div class="flex-grow-1">
            <label class="form-label small mb-1" for="rem-text">About</label>
            <input id="rem-text" class="form-control form-control-sm" maxlength="500" @bind="reminderText" />
        </div>
        <button class="btn btn-outline-primary btn-sm" @onclick="RemindAsync" disabled="@reminderBusy">Set</button>
    </div>
    @if (reminderMessage is not null)
    {
        <div class="meta-mono mt-2">@reminderMessage</div>
    }
</div>

<div class="mt-4">
    <a class="meta-mono" href="/app/guilds/@GuildId/settings">server settings &amp; calendar feed →</a>
</div>

@code {
    [Parameter] public long GuildId { get; set; }

    [Inject] private AuthApiClient AuthApi { get; set; } = default!;

    private List<EventDto>? events;
    private string? error;
    private bool includePast;
    private string reminderWhen = "";
    private string reminderText = "";
    private string? reminderMessage;
    private bool reminderBusy;

    protected override Task OnParametersSetAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        var result = await Api.ListEventsAsync(GuildId, includePast);
        if (!result.Success)
        {
            error = result.Error;
            return;
        }

        error = null;
        events = result.Value;
    }

    private async Task RemindAsync()
    {
        reminderMessage = null;
        if (string.IsNullOrWhiteSpace(reminderWhen) || string.IsNullOrWhiteSpace(reminderText))
        {
            reminderMessage = "Both fields are required.";
            return;
        }

        reminderBusy = true;
        // UserId/ChannelId are forced server-side for web callers; 0s are placeholders.
        var result = await Api.CreateReminderAsync(new CreateReminderRequest(
            GuildId, 0, 0, reminderWhen, reminderText));
        reminderBusy = false;

        if (!result.Success || result.Value is null)
        {
            reminderMessage = $"❌ {result.Error}";
            return;
        }

        reminderMessage = $"⏰ Reminder set for {result.Value.FireAtUtc.ToLocalTime():f}.";
        reminderWhen = "";
        reminderText = "";
    }
}
