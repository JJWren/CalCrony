@page "/app/events/{EventId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject CalCronyWebApiClient Api
@inject AuthApiClient AuthApi

<PageTitle>Event — CalCrony</PageTitle>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (ev is null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <p class="meta-mono text-uppercase mb-2"><a href="/app/guilds/@ev.GuildId/events">← Back to events</a></p>
    <div class="d-flex gap-3 align-items-start flex-wrap">
        <div class="datechip" style="min-width:4rem">
            <div class="datechip-month">@ev.StartsAtUtc.ToLocalTime().ToString("MMM")</div>
            <div class="datechip-day">@ev.StartsAtUtc.ToLocalTime().Day</div>
        </div>
        <div class="flex-grow-1 min-w-0">
            <h1 class="h3 mb-1">@ev.Title</h1>
            <div class="meta-mono d-flex gap-3 flex-wrap">
                <span><LocalTime Utc="ev.StartsAtUtc" /> · @(ev.DurationMinutes ?? 60) min</span>
                @if (ev.RecurrenceSummary is not null)
                {
                    <span>🔁 @ev.RecurrenceSummary</span>
                }
                @if (!string.IsNullOrWhiteSpace(ev.Location))
                {
                    <span>📍 @ev.Location</span>
                }
            </div>
        </div>
        @if (CanManage)
        {
            <div class="d-flex gap-2 flex-shrink-0 flex-wrap">
                <a class="btn btn-outline-primary btn-sm" href="/app/events/@ev.Id/edit">Edit</a>
                @if (IsLiveSeries)
                {
                    <button class="btn btn-outline-primary btn-sm" @onclick="ToggleScheduleEditorAsync">Edit schedule</button>
                    @if (!confirmingSkip)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => confirmingSkip = true">Skip occurrence</button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm" @onclick="SkipAsync" disabled="@busy">Really skip?</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingSkip = false">Keep</button>
                    }
                    @if (!confirmingStop)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingStop = true">Stop repeating</button>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-sm" @onclick="StopAsync" disabled="@busy">Really stop?</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingStop = false">Keep</button>
                    }
                }
                @if (!confirmingDelete)
                {
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingDelete = true">Delete</button>
                }
                else
                {
                    <button class="btn btn-danger btn-sm" @onclick="DeleteAsync" disabled="@busy">
                        @(IsLiveSeries ? "Really delete? This stops the series." : "Really delete?")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingDelete = false">Keep</button>
                }
            </div>
        }
    </div>

    @if (IsEndedSeries)
    {
        <div class="card p-3 mt-3" style="max-width:560px">
            <div>🔁 This event was part of a repeating series that has ended.</div>
            @if (CanManage && !showScheduleEditor)
            {
                <div class="mt-2">
                    <button class="btn btn-outline-primary btn-sm" @onclick="ToggleScheduleEditorAsync">Edit schedule &amp; resume</button>
                </div>
            }
        </div>
    }

    @if (showScheduleEditor)
    {
        <div class="card p-3 mt-3" style="max-width:560px">
            <h2 class="h6 mb-2">@(IsEndedSeries ? "Edit schedule & resume" : "Edit schedule")</h2>
            @if (series is null)
            {
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
            }
            else
            {
                <div class="mb-2">
                    <label class="form-label small mb-1" for="se-repeat">Repeats</label>
                    <select id="se-repeat" class="form-select form-select-sm" @bind="scheduleKind">
                        @if (!IsEndedSeries)
                        {
                            <option value="@ScheduleKind.None">Doesn't repeat (stop the series)</option>
                        }
                        <option value="@ScheduleKind.Daily">Daily</option>
                        <option value="@ScheduleKind.Weekly">Weekly</option>
                        <option value="@ScheduleKind.MonthlySameDate">Monthly (same date)</option>
                        <option value="@ScheduleKind.MonthlyNthWeekday">Monthly (nth weekday, e.g. 3rd Friday)</option>
                    </select>
                </div>
                @if (scheduleKind == ScheduleKind.None)
                {
                    <p class="text-body-secondary small mb-2">Stops future occurrences — this event still happens and becomes a one-off.</p>
                }
                <div class="mb-2" hidden="@(scheduleKind == ScheduleKind.None)">
                    <label class="form-label small mb-1" for="se-interval">Every</label>
                    <div class="d-flex align-items-center gap-2">
                        <input id="se-interval" class="form-control form-control-sm" type="number" min="1" max="12" style="width:6rem" @bind="scheduleInterval" />
                        <span class="text-body-secondary small">@ScheduleUnitLabel</span>
                    </div>
                </div>
                <div class="mb-2" hidden="@(scheduleKind == ScheduleKind.None)">
                    <label class="form-label small mb-1 d-block">Ends</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="se-ends" id="se-ends-never"
                               checked="@(scheduleEndMode == ScheduleEndMode.Never)" @onchange="() => scheduleEndMode = ScheduleEndMode.Never" />
                        <label class="form-check-label small" for="se-ends-never">Never</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="se-ends" id="se-ends-until"
                               checked="@(scheduleEndMode == ScheduleEndMode.Until)" @onchange="() => scheduleEndMode = ScheduleEndMode.Until" />
                        <label class="form-check-label small" for="se-ends-until">On a date</label>
                    </div>
                    @if (scheduleEndMode == ScheduleEndMode.Until)
                    {
                        <div class="ms-4 mb-1">
                            <input id="se-until" class="form-control form-control-sm" placeholder="Aug 30 · in 2 months" aria-label="Series until"
                                   @bind="scheduleUntil" @bind:after="PreviewScheduleUntilAsync" />
                            @if (scheduleUntilPreview is not null)
                            {
                                <div class="form-text text-primary mb-0">→ last on <LocalTime Utc="scheduleUntilPreview.Value" Format="D" /></div>
                            }
                            else if (scheduleUntilError is not null)
                            {
                                <div class="form-text text-danger mb-0">@scheduleUntilError</div>
                            }
                        </div>
                    }
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="se-ends" id="se-ends-count"
                               checked="@(scheduleEndMode == ScheduleEndMode.Count)" @onchange="() => scheduleEndMode = ScheduleEndMode.Count" />
                        <label class="form-check-label small" for="se-ends-count">After a number of times</label>
                    </div>
                    @if (scheduleEndMode == ScheduleEndMode.Count)
                    {
                        <div class="ms-4">
                            <input id="se-count" class="form-control form-control-sm" type="number"
                                   min="@Math.Max(2, series.OccurrenceCount + 1)" max="500" style="width:8rem"
                                   aria-label="Series count" @bind="scheduleCount" />
                            <div class="form-text mb-0">has run @series.OccurrenceCount time@(series.OccurrenceCount == 1 ? "" : "s") so far</div>
                        </div>
                    }
                </div>

                @if (scheduleError is not null)
                {
                    <div class="alert alert-danger py-1 mb-2 small">@scheduleError</div>
                }

                <div class="d-flex gap-2">
                    <button class="btn btn-primary btn-sm" @onclick="SaveScheduleAsync" disabled="@busy">
                        @(scheduleKind == ScheduleKind.None ? "Stop repeating" : IsEndedSeries ? "Save and resume" : "Save schedule")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => showScheduleEditor = false" disabled="@busy">Cancel</button>
                </div>
            }
        </div>
    }
    @if (scheduleNote is not null)
    {
        <p class="meta-mono mt-2">@scheduleNote</p>
    }

    @if (!string.IsNullOrWhiteSpace(ev.Description))
    {
        <p class="text-body-secondary mt-3" style="max-width:66ch">@ev.Description</p>
    }

    @if (ev.ImageUrl is not null)
    {
        <img src="@ev.ImageUrl" class="rounded mt-2" style="max-width:100%;max-height:280px" alt="" />
    }

    <h2 class="h5 mt-4 mb-2">Your RSVP</h2>
    <RsvpButtons Event="ev" UserId="UserId" OnChanged="dto => ev = dto" />
    <p class="meta-mono mt-2"><span class="status-dot status-free"></span> your choice updates the Discord embed within ~15 seconds</p>

    <h2 class="h5 mt-4 mb-2">Who's in</h2>
    <div class="card p-3">
        <div class="row g-3">
            @foreach (var option in ev.Options.OrderBy(o => o.SortOrder))
            {
                var members = ev.Rsvps.Where(r => r.OptionId == option.Id).ToList();
                <div class="col-12 col-md-4">
                    <div class="fw-semibold small">@option.Emote @option.Label <span class="meta-mono">(@members.Count@(option.Capacity is int cap ? $"/{cap}" : ""))</span></div>
                    @if (members.Count == 0)
                    {
                        <div class="text-body-secondary small py-1">—</div>
                    }
                    else
                    {
                        @foreach (var rsvp in members)
                        {
                            <div class="d-flex align-items-center gap-2 py-1 small text-body-secondary">
                                <span class="avatar avatar-sm">@NameFor(rsvp.UserId)[..1]</span>@NameFor(rsvp.UserId)
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>

    <h2 class="h5 mt-4 mb-2">Availability <span class="meta-mono fw-normal">— Going members, event window</span></h2>
    <div class="card p-3">
        @if (availability is null)
        {
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        }
        else
        {
            <AvailabilityGrid Response="availability" NameResolver="NameFor" />
        }
    </div>

    <h2 class="h5 mt-4 mb-2">Scheduled notifications <span class="meta-mono fw-normal">(max 5)</span></h2>
    <div class="card p-3" style="max-width:560px">
        @if (notifications is { Count: > 0 })
        {
            <ul class="list-unstyled meta-mono mb-2">
                @foreach (var n in notifications)
                {
                    <li class="py-1 d-flex align-items-center gap-2 flex-wrap">
                        <span>🔔 @n.MinutesBefore min before@(n.Message is null ? "" : $" — “{n.Message}”")</span>
                        @if (CanManage && askingRemoveScopeFor != n.Id)
                        {
                            <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => RemoveNotificationClicked(n.Id)">remove</button>
                        }
                        else if (CanManage)
                        {
                            <span class="meta-mono">remove from:</span>
                            <button class="btn btn-link btn-sm p-0" disabled="@busy" @onclick="() => DeleteNotificationAsync(n.Id, EditScope.Occurrence)">this occurrence</button>
                            <button class="btn btn-link btn-sm p-0" disabled="@busy" @onclick="() => DeleteNotificationAsync(n.Id, EditScope.Series)">all future</button>
                            <button class="btn btn-link btn-sm p-0 text-body-secondary" disabled="@busy" @onclick="() => askingRemoveScopeFor = null">cancel</button>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-body-secondary small mb-2">No notifications yet.</p>
        }
        @if (CanManage && (notifications?.Count ?? 0) < 5)
        {
            <div class="d-flex gap-2 flex-wrap align-items-end">
                <div>
                    <label class="form-label small mb-1" for="notif-min">Minutes before</label>
                    <input id="notif-min" class="form-control form-control-sm" type="number" min="0" style="width:8rem" @bind="newNotificationMinutes" />
                </div>
                <div class="flex-grow-1">
                    <label class="form-label small mb-1" for="notif-msg">Message (optional)</label>
                    <input id="notif-msg" class="form-control form-control-sm" maxlength="1024" @bind="newNotificationMessage" />
                </div>
                @if (!askingAddScope)
                {
                    <button class="btn btn-outline-primary btn-sm" @onclick="AddNotificationClicked" disabled="@busy">Add</button>
                }
            </div>
            @if (askingAddScope)
            {
                <div class="d-flex gap-2 align-items-center mt-2 flex-wrap">
                    <span class="small">Add to:</span>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => AddNotificationAsync(EditScope.Occurrence)" disabled="@busy">This occurrence</button>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => AddNotificationAsync(EditScope.Series)" disabled="@busy">All future occurrences</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => askingAddScope = false" disabled="@busy">Cancel</button>
                </div>
            }
        }
        @if (notificationError is not null)
        {
            <div class="alert alert-danger py-1 mt-2 mb-0 small">@notificationError</div>
        }
    </div>
}

@code {
    [Parameter] public Guid EventId { get; set; }

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private EventDto? ev;
    private AvailabilityResponse? availability;
    private List<EventNotificationDto>? notifications;
    private string? error;
    private string? notificationError;
    private bool confirmingDelete;
    private bool confirmingSkip;
    private bool confirmingStop;
    private bool askingAddScope;
    private Guid? askingRemoveScopeFor;
    private bool busy;
    private bool isGuildManager;
    private int newNotificationMinutes = 30;
    private string? newNotificationMessage;

    private long UserId => AuthApi.Session?.UserId ?? 0;

    private bool CanManage => ev is not null && (ev.CreatorId == UserId || isGuildManager);

    /// <summary>Live occurrence of a running series — the states where skip/stop/scope apply.</summary>
    private bool IsLiveSeries =>
        ev is { SeriesId: not null, RecurrenceSummary: not null, Status: EventStatus.Scheduled or EventStatus.Started };

    /// <summary>Summary is null iff the series ended, and past occurrences keep SeriesId — so the
    /// revive affordance is derivable from the EventDto alone. Past-occurrence pages are the only
    /// reachable pages of a fully-ended series, which is why the card lives here.</summary>
    private bool IsEndedSeries => ev is { SeriesId: not null, RecurrenceSummary: null };

    private enum ScheduleKind { None, Daily, Weekly, MonthlySameDate, MonthlyNthWeekday }

    private enum ScheduleEndMode { Never, Until, Count }

    private bool showScheduleEditor;
    private SeriesDto? series;
    private ScheduleKind scheduleKind;
    private int scheduleInterval = 1;
    private ScheduleEndMode scheduleEndMode;
    private string scheduleUntil = "";
    private DateTimeOffset? scheduleUntilPreview;
    private string? scheduleUntilError;
    private int? scheduleCount;
    private string? scheduleError;
    private string? scheduleNote;

    private string ScheduleUnitLabel => scheduleKind switch
    {
        ScheduleKind.Daily => scheduleInterval == 1 ? "day" : "days",
        ScheduleKind.Weekly => scheduleInterval == 1 ? "week" : "weeks",
        _ => scheduleInterval == 1 ? "month" : "months",
    };

    private async Task ToggleScheduleEditorAsync()
    {
        if (showScheduleEditor)
        {
            showScheduleEditor = false;
            return;
        }

        showScheduleEditor = true;
        scheduleError = null;
        scheduleNote = null;
        scheduleUntilPreview = null;
        scheduleUntilError = null;

        // Refetch and re-prefill on every open: a cancelled edit's typed-but-unsaved values must
        // not survive a reopen, and the server state may have moved meanwhile.
        series = null;
        var result = await Api.GetSeriesAsync(ev!.SeriesId!.Value);
        if (!result.Success || result.Value is null)
        {
            scheduleError = result.Error;
            return;
        }

        series = result.Value;
        scheduleKind = (series.Unit, series.MonthlyMode) switch
        {
            (RecurrenceUnit.Day, _) => ScheduleKind.Daily,
            (RecurrenceUnit.Week, _) => ScheduleKind.Weekly,
            (_, MonthlyMode.NthWeekday) => ScheduleKind.MonthlyNthWeekday,
            _ => ScheduleKind.MonthlySameDate,
        };
        scheduleInterval = series.Interval;
        scheduleEndMode = series.UntilDate is not null ? ScheduleEndMode.Until
            : series.MaxOccurrences is not null ? ScheduleEndMode.Count
            : ScheduleEndMode.Never;
        scheduleUntil = series.UntilDate ?? "";
        scheduleCount = series.MaxOccurrences;
    }

    private async Task PreviewScheduleUntilAsync()
    {
        scheduleUntilPreview = null;
        scheduleUntilError = null;
        if (string.IsNullOrWhiteSpace(scheduleUntil))
        {
            return;
        }

        // Preview in the SERIES zone — the PATCH endpoint parses there, and the viewer's own
        // zone could disagree (e.g. relative text near midnight).
        var result = await Api.ParseDateTimeAsync(new ParseDateTimeRequest(
            scheduleUntil, null, ev!.GuildId, series?.TimeZone));
        if (result.Success && result.Value is not null)
        {
            scheduleUntilPreview = result.Value.Utc;
        }
        else
        {
            scheduleUntilError = result.Error;
        }
    }

    private async Task SaveScheduleAsync()
    {
        scheduleError = null;

        // "Doesn't repeat" = stop the series: this occurrence survives as a one-off.
        if (scheduleKind == ScheduleKind.None)
        {
            busy = true;
            var stop = await Api.StopSeriesAsync(ev!.SeriesId!.Value);
            busy = false;
            if (!stop.Success)
            {
                scheduleError = stop.Error;
                return;
            }

            showScheduleEditor = false;
            series = null;
            ev = (await Api.GetEventAsync(EventId)).Value ?? ev;
            scheduleNote = "Series stopped — this event still happens, and no more occurrences will be created.";
            return;
        }

        if (scheduleEndMode == ScheduleEndMode.Until && string.IsNullOrWhiteSpace(scheduleUntil))
        {
            scheduleError = "Enter the date the series should stop repeating.";
            return;
        }

        if (scheduleEndMode == ScheduleEndMode.Count && scheduleCount is null)
        {
            scheduleError = "Enter how many times the series should run in total.";
            return;
        }

        var wasEnded = IsEndedSeries;
        var (unit, mode) = scheduleKind switch
        {
            ScheduleKind.Daily => (RecurrenceUnit.Day, MonthlyMode.DayOfMonth),
            ScheduleKind.Weekly => (RecurrenceUnit.Week, MonthlyMode.DayOfMonth),
            ScheduleKind.MonthlySameDate => (RecurrenceUnit.Month, MonthlyMode.DayOfMonth),
            _ => (RecurrenceUnit.Month, MonthlyMode.NthWeekday),
        };

        busy = true;
        // Always explicit values — the web form never sends Keep.
        var result = await Api.UpdateSeriesAsync(ev!.SeriesId!.Value, new UpdateSeriesRequest(
            unit, scheduleInterval, mode,
            scheduleEndMode switch
            {
                ScheduleEndMode.Until => SeriesEndChoice.Until,
                ScheduleEndMode.Count => SeriesEndChoice.Count,
                _ => SeriesEndChoice.Never,
            },
            scheduleEndMode == ScheduleEndMode.Until ? scheduleUntil : null,
            scheduleEndMode == ScheduleEndMode.Count ? scheduleCount : null));
        busy = false;

        if (!result.Success || result.Value is null)
        {
            scheduleError = result.Error;
            return;
        }

        series = result.Value;
        showScheduleEditor = false;
        ev = (await Api.GetEventAsync(EventId)).Value ?? ev;
        scheduleNote = wasEnded && series.LiveEventId is null
            ? "Series resumed — the next occurrence will be scheduled within ~15 seconds."
            : "Schedule updated — the Discord embed refreshes within ~15 seconds.";
    }

    protected override async Task OnParametersSetAsync()
    {
        // Navigating between event pages reuses this component instance — another series'
        // cached schedule (or an open editor) must not carry over.
        series = null;
        showScheduleEditor = false;
        scheduleNote = null;
        scheduleError = null;

        var result = await Api.GetEventAsync(EventId);
        if (!result.Success || result.Value is null)
        {
            error = result.Error ?? "Event not found.";
            return;
        }

        ev = result.Value;

        var availabilityTask = Api.GetEventAvailabilityAsync(EventId);
        var notificationsTask = Api.ListNotificationsAsync(EventId);
        var guildsTask = Api.GetMyGuildsAsync();
        availability = (await availabilityTask).Value;
        notifications = (await notificationsTask).Value;
        isGuildManager = (await guildsTask).Value?.Guilds
            .Any(g => g.Id == ev.GuildId && g.CanManage) ?? false;
    }

    private async Task DeleteAsync()
    {
        busy = true;
        var result = await Api.DeleteEventAsync(EventId);
        busy = false;
        if (!result.Success)
        {
            error = result.Error;
            return;
        }

        Nav.NavigateTo($"/app/guilds/{ev!.GuildId}/events");
    }

    private async Task SkipAsync()
    {
        busy = true;
        var result = await Api.SkipOccurrenceAsync(EventId);
        busy = false;
        confirmingSkip = false;
        if (!result.Success || result.Value is null)
        {
            error = result.Error;
            return;
        }

        // Land on the replacement occurrence; if the skip exhausted the series, back to the list.
        Nav.NavigateTo(result.Value.NextEvent is { } next
            ? $"/app/events/{next.Id}"
            : $"/app/guilds/{ev!.GuildId}/events");
    }

    private async Task StopAsync()
    {
        busy = true;
        var result = await Api.StopSeriesAsync(ev!.SeriesId!.Value);
        busy = false;
        confirmingStop = false;
        if (!result.Success)
        {
            error = result.Error;
            return;
        }

        // Reload — the event survives as the final occurrence and the 🔁 chip drops.
        ev = (await Api.GetEventAsync(EventId)).Value ?? ev;
    }

    private Task AddNotificationClicked()
    {
        if (IsLiveSeries)
        {
            askingAddScope = true;
            return Task.CompletedTask;
        }

        return AddNotificationAsync(null);
    }

    private Task RemoveNotificationClicked(Guid notificationId)
    {
        if (IsLiveSeries)
        {
            askingRemoveScopeFor = notificationId;
            return Task.CompletedTask;
        }

        return DeleteNotificationAsync(notificationId, null);
    }

    private async Task AddNotificationAsync(EditScope? scope)
    {
        notificationError = null;
        askingAddScope = false;
        busy = true;
        var result = await Api.CreateNotificationAsync(EventId,
            new CreateEventNotificationRequest(
                newNotificationMinutes,
                string.IsNullOrWhiteSpace(newNotificationMessage) ? null : newNotificationMessage,
                Scope: scope));
        busy = false;
        if (!result.Success || result.Value is null)
        {
            notificationError = result.Error;
            return;
        }

        notifications = (await Api.ListNotificationsAsync(EventId)).Value;
        newNotificationMessage = null;
    }

    private async Task DeleteNotificationAsync(Guid notificationId, EditScope? scope)
    {
        notificationError = null;
        askingRemoveScopeFor = null;
        busy = true;
        var result = await Api.DeleteNotificationAsync(EventId, notificationId, scope);
        busy = false;
        if (!result.Success)
        {
            notificationError = result.Error;
            return;
        }

        notifications = (await Api.ListNotificationsAsync(EventId)).Value;
    }

    // The web only knows Discord user ids from RSVP rows; show "you" for the signed-in user.
    private string NameFor(long userId) =>
        userId == UserId ? (AuthApi.Session?.Username ?? "you") : $"user {userId}";
}
