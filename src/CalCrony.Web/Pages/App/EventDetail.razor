@page "/app/events/{EventId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject CalCronyWebApiClient Api
@inject AuthApiClient AuthApi

<PageTitle>Event — CalCrony</PageTitle>

@if (error is not null)
{
    <div class="alert alert-danger">@error</div>
}
else if (ev is null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <p class="meta-mono text-uppercase mb-2"><a href="/app/guilds/@ev.GuildId/events">← Back to events</a></p>
    <div class="d-flex gap-3 align-items-start flex-wrap">
        <div class="datechip" style="min-width:4rem">
            <div class="datechip-month">@ev.StartsAtUtc.ToLocalTime().ToString("MMM")</div>
            <div class="datechip-day">@ev.StartsAtUtc.ToLocalTime().Day</div>
        </div>
        <div class="flex-grow-1 min-w-0">
            <h1 class="h3 mb-1">@ev.Title</h1>
            <div class="meta-mono d-flex gap-3 flex-wrap">
                <span><LocalTime Utc="ev.StartsAtUtc" /> · @(ev.DurationMinutes ?? 60) min</span>
                @if (ev.RecurrenceSummary is not null)
                {
                    <span>🔁 @ev.RecurrenceSummary</span>
                }
                @if (!string.IsNullOrWhiteSpace(ev.Location))
                {
                    <span>📍 @ev.Location</span>
                }
            </div>
        </div>
        @if (CanManage)
        {
            <div class="d-flex gap-2 flex-shrink-0 flex-wrap">
                <a class="btn btn-outline-primary btn-sm" href="/app/events/@ev.Id/edit">Edit</a>
                @if (IsLiveSeries)
                {
                    @if (!confirmingSkip)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => confirmingSkip = true">Skip occurrence</button>
                    }
                    else
                    {
                        <button class="btn btn-primary btn-sm" @onclick="SkipAsync" disabled="@busy">Really skip?</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingSkip = false">Keep</button>
                    }
                    @if (!confirmingStop)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingStop = true">Stop repeating</button>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-sm" @onclick="StopAsync" disabled="@busy">Really stop?</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingStop = false">Keep</button>
                    }
                }
                @if (!confirmingDelete)
                {
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingDelete = true">Delete</button>
                }
                else
                {
                    <button class="btn btn-danger btn-sm" @onclick="DeleteAsync" disabled="@busy">
                        @(IsLiveSeries ? "Really delete? This stops the series." : "Really delete?")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmingDelete = false">Keep</button>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrWhiteSpace(ev.Description))
    {
        <p class="text-body-secondary mt-3" style="max-width:66ch">@ev.Description</p>
    }

    @if (ev.ImageUrl is not null)
    {
        <img src="@ev.ImageUrl" class="rounded mt-2" style="max-width:100%;max-height:280px" alt="" />
    }

    <h2 class="h5 mt-4 mb-2">Your RSVP</h2>
    <RsvpButtons Event="ev" UserId="UserId" OnChanged="dto => ev = dto" />
    <p class="meta-mono mt-2"><span class="status-dot status-free"></span> your choice updates the Discord embed within ~15 seconds</p>

    <h2 class="h5 mt-4 mb-2">Who's in</h2>
    <div class="card p-3">
        <div class="row g-3">
            @foreach (var option in ev.Options.OrderBy(o => o.SortOrder))
            {
                var members = ev.Rsvps.Where(r => r.OptionId == option.Id).ToList();
                <div class="col-12 col-md-4">
                    <div class="fw-semibold small">@option.Emote @option.Label <span class="meta-mono">(@members.Count@(option.Capacity is int cap ? $"/{cap}" : ""))</span></div>
                    @if (members.Count == 0)
                    {
                        <div class="text-body-secondary small py-1">—</div>
                    }
                    else
                    {
                        @foreach (var rsvp in members)
                        {
                            <div class="d-flex align-items-center gap-2 py-1 small text-body-secondary">
                                <span class="avatar avatar-sm">@NameFor(rsvp.UserId)[..1]</span>@NameFor(rsvp.UserId)
                            </div>
                        }
                    }
                </div>
            }
        </div>
    </div>

    <h2 class="h5 mt-4 mb-2">Availability <span class="meta-mono fw-normal">— Going members, event window</span></h2>
    <div class="card p-3">
        @if (availability is null)
        {
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        }
        else
        {
            <AvailabilityGrid Response="availability" NameResolver="NameFor" />
        }
    </div>

    <h2 class="h5 mt-4 mb-2">Scheduled notifications <span class="meta-mono fw-normal">(max 5)</span></h2>
    <div class="card p-3" style="max-width:560px">
        @if (notifications is { Count: > 0 })
        {
            <ul class="list-unstyled meta-mono mb-2">
                @foreach (var n in notifications)
                {
                    <li class="py-1 d-flex align-items-center gap-2 flex-wrap">
                        <span>🔔 @n.MinutesBefore min before@(n.Message is null ? "" : $" — “{n.Message}”")</span>
                        @if (CanManage && askingRemoveScopeFor != n.Id)
                        {
                            <button class="btn btn-link btn-sm text-danger p-0" @onclick="() => RemoveNotificationClicked(n.Id)">remove</button>
                        }
                        else if (CanManage)
                        {
                            <span class="meta-mono">remove from:</span>
                            <button class="btn btn-link btn-sm p-0" disabled="@busy" @onclick="() => DeleteNotificationAsync(n.Id, EditScope.Occurrence)">this occurrence</button>
                            <button class="btn btn-link btn-sm p-0" disabled="@busy" @onclick="() => DeleteNotificationAsync(n.Id, EditScope.Series)">all future</button>
                            <button class="btn btn-link btn-sm p-0 text-body-secondary" disabled="@busy" @onclick="() => askingRemoveScopeFor = null">cancel</button>
                        }
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-body-secondary small mb-2">No notifications yet.</p>
        }
        @if (CanManage && (notifications?.Count ?? 0) < 5)
        {
            <div class="d-flex gap-2 flex-wrap align-items-end">
                <div>
                    <label class="form-label small mb-1" for="notif-min">Minutes before</label>
                    <input id="notif-min" class="form-control form-control-sm" type="number" min="0" style="width:8rem" @bind="newNotificationMinutes" />
                </div>
                <div class="flex-grow-1">
                    <label class="form-label small mb-1" for="notif-msg">Message (optional)</label>
                    <input id="notif-msg" class="form-control form-control-sm" maxlength="1024" @bind="newNotificationMessage" />
                </div>
                @if (!askingAddScope)
                {
                    <button class="btn btn-outline-primary btn-sm" @onclick="AddNotificationClicked" disabled="@busy">Add</button>
                }
            </div>
            @if (askingAddScope)
            {
                <div class="d-flex gap-2 align-items-center mt-2 flex-wrap">
                    <span class="small">Add to:</span>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => AddNotificationAsync(EditScope.Occurrence)" disabled="@busy">This occurrence</button>
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => AddNotificationAsync(EditScope.Series)" disabled="@busy">All future occurrences</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => askingAddScope = false" disabled="@busy">Cancel</button>
                </div>
            }
        }
        @if (notificationError is not null)
        {
            <div class="alert alert-danger py-1 mt-2 mb-0 small">@notificationError</div>
        }
    </div>
}

@code {
    [Parameter] public Guid EventId { get; set; }

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private EventDto? ev;
    private AvailabilityResponse? availability;
    private List<EventNotificationDto>? notifications;
    private string? error;
    private string? notificationError;
    private bool confirmingDelete;
    private bool confirmingSkip;
    private bool confirmingStop;
    private bool askingAddScope;
    private Guid? askingRemoveScopeFor;
    private bool busy;
    private bool isGuildManager;
    private int newNotificationMinutes = 30;
    private string? newNotificationMessage;

    private long UserId => AuthApi.Session?.UserId ?? 0;

    private bool CanManage => ev is not null && (ev.CreatorId == UserId || isGuildManager);

    /// <summary>Live occurrence of a running series — the states where skip/stop/scope apply.</summary>
    private bool IsLiveSeries =>
        ev is { SeriesId: not null, RecurrenceSummary: not null, Status: EventStatus.Scheduled or EventStatus.Started };

    protected override async Task OnParametersSetAsync()
    {
        var result = await Api.GetEventAsync(EventId);
        if (!result.Success || result.Value is null)
        {
            error = result.Error ?? "Event not found.";
            return;
        }

        ev = result.Value;

        var availabilityTask = Api.GetEventAvailabilityAsync(EventId);
        var notificationsTask = Api.ListNotificationsAsync(EventId);
        var guildsTask = Api.GetMyGuildsAsync();
        availability = (await availabilityTask).Value;
        notifications = (await notificationsTask).Value;
        isGuildManager = (await guildsTask).Value?.Guilds
            .Any(g => g.Id == ev.GuildId && g.CanManage) ?? false;
    }

    private async Task DeleteAsync()
    {
        busy = true;
        var result = await Api.DeleteEventAsync(EventId);
        busy = false;
        if (!result.Success)
        {
            error = result.Error;
            return;
        }

        Nav.NavigateTo($"/app/guilds/{ev!.GuildId}/events");
    }

    private async Task SkipAsync()
    {
        busy = true;
        var result = await Api.SkipOccurrenceAsync(EventId);
        busy = false;
        confirmingSkip = false;
        if (!result.Success || result.Value is null)
        {
            error = result.Error;
            return;
        }

        // Land on the replacement occurrence; if the skip exhausted the series, back to the list.
        Nav.NavigateTo(result.Value.NextEvent is { } next
            ? $"/app/events/{next.Id}"
            : $"/app/guilds/{ev!.GuildId}/events");
    }

    private async Task StopAsync()
    {
        busy = true;
        var result = await Api.StopSeriesAsync(ev!.SeriesId!.Value);
        busy = false;
        confirmingStop = false;
        if (!result.Success)
        {
            error = result.Error;
            return;
        }

        // Reload — the event survives as the final occurrence and the 🔁 chip drops.
        ev = (await Api.GetEventAsync(EventId)).Value ?? ev;
    }

    private Task AddNotificationClicked()
    {
        if (IsLiveSeries)
        {
            askingAddScope = true;
            return Task.CompletedTask;
        }

        return AddNotificationAsync(null);
    }

    private Task RemoveNotificationClicked(Guid notificationId)
    {
        if (IsLiveSeries)
        {
            askingRemoveScopeFor = notificationId;
            return Task.CompletedTask;
        }

        return DeleteNotificationAsync(notificationId, null);
    }

    private async Task AddNotificationAsync(EditScope? scope)
    {
        notificationError = null;
        askingAddScope = false;
        busy = true;
        var result = await Api.CreateNotificationAsync(EventId,
            new CreateEventNotificationRequest(
                newNotificationMinutes,
                string.IsNullOrWhiteSpace(newNotificationMessage) ? null : newNotificationMessage,
                Scope: scope));
        busy = false;
        if (!result.Success || result.Value is null)
        {
            notificationError = result.Error;
            return;
        }

        notifications = (await Api.ListNotificationsAsync(EventId)).Value;
        newNotificationMessage = null;
    }

    private async Task DeleteNotificationAsync(Guid notificationId, EditScope? scope)
    {
        notificationError = null;
        askingRemoveScopeFor = null;
        busy = true;
        var result = await Api.DeleteNotificationAsync(EventId, notificationId, scope);
        busy = false;
        if (!result.Success)
        {
            notificationError = result.Error;
            return;
        }

        notifications = (await Api.ListNotificationsAsync(EventId)).Value;
    }

    // The web only knows Discord user ids from RSVP rows; show "you" for the signed-in user.
    private string NameFor(long userId) =>
        userId == UserId ? (AuthApi.Session?.Username ?? "you") : $"user {userId}";
}
